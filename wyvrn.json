{
  "name": "cppzmq",
  "version": "4.11.0.0",
  "schemaVersion": 2,
  "kind": "HeaderOnlyLib",
  "description": "Header-only C++ binding for libzmq",
  "dependencies": {
    "libzmq": "^4.3.5.0"
  },
  "build": {
    "system": "cmake",
    "configs": [
      "Debug",
      "Release",
      "RelWithDebInfo",
      "MinSizeRel"
    ],
    "configure": [
      "-DCPPZMQ_BUILD_TESTS=OFF"
    ],
    "installDir": "install"
  }
}
